<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import java.lang.String?>

<AnchorPane minHeight="300.0" minWidth="400.0" xmlns="http://javafx.com/javafx/8.0.45" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stp.eauth.automator.helpers.CommontInputController">
   <children>
      <VBox alignment="CENTER" layoutX="131.0" layoutY="50.0" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="4.0" text="Enter Input" />            
            <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="100.0" spacing="10.0">               
               <children>                                             
                  <Label fx:id=txtLabel alignment="CENTER_LEFT" minWidth="50.0" text="" />
                  <TextField fx:id="tfInput" HBox.hgrow="ALWAYS" />                  
               </children>
               <padding>
                  <Insets right="15.0" bottom="10.0"/>
               </padding>
            </HBox>
            <HBox alignment="BOTTOM_RIGHT"  spacing="5.0">
               <children>
			      <Button mnemonicParsing="false" onAction="#btnCancelClicked" text="Cancel" />			   
			      <Button mnemonicParsing="true" onAction="#btnSaveUserClicked" text="_Save" />
               </children>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <padding>
                  <Insets right="15.0" bottom="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>